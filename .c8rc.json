{
  "reporter": ["text", "html", "lcov"],
  "reports-dir": "coverage",
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/test/**",
    "**/tests/**",
    "**/coverage/**",
    "src/cli.ts",
    "scripts/**",
    "dist/**"
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "check-coverage": true,
  "lines": 0,
  "functions": 0,
  "branches": 0,
  "statements": 0,
  "all": true
}
