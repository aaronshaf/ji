{
  "name": "ji",
  "version": "0.1.0",
  "description": "CLI for accessing Jira and Confluence with local SQLite sync",
  "type": "module",
  "bin": {
    "ji": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "daemon": "bun run src/daemon/index.ts",
    "test": "bun test",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "ji": "bun run src/cli.ts"
  },
  "keywords": ["jira", "confluence", "cli", "sqlite", "daemon"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "ora": "^8.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "bun-types": "^1.0.20",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0"
  }
}
