{
  "name": "ji",
  "version": "0.1.0",
  "description": "CLI for accessing Jira and Confluence with local SQLite sync",
  "type": "module",
  "bin": {
    "ji": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "daemon": "bun run src/daemon/index.ts",
    "test": "bun test",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "ji": "bun run src/cli.ts",
    "pre-commit": "bun run typecheck && bun run lint",
    "prepare": "node scripts/install-hooks.cjs"
  },
  "keywords": ["jira", "confluence", "cli", "sqlite", "daemon"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "meilisearch": "latest",
    "ora": "^8.2.0",
    "turndown": "^7.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "bun-types": "^1.0.20",
    "eslint": "^9.30.0",
    "typescript": "^5.3.3"
  }
}
