{
  "name": "ji",
  "version": "0.1.0",
  "description": "CLI for accessing Jira and Confluence with local SQLite sync",
  "type": "module",
  "bin": {
    "ji": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "daemon": "bun run src/daemon/index.ts",
    "test": "bun test",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "ji": "bun run src/cli.ts",
    "pre-commit": "bun run typecheck && biome check",
    "prepare": "node scripts/install-hooks.cjs"
  },
  "keywords": [
    "jira",
    "confluence",
    "cli",
    "sqlite",
    "daemon"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@effect/schema": "^0.75.5",
    "chalk": "^5.3.0",
    "date-fns": "^4.1.0",
    "effect": "^3.16.10",
    "meilisearch": "latest",
    "ora": "^8.2.0",
    "turndown": "^7.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@types/turndown": "^5.0.5",
    "bun-types": "^1.0.20",
    "typescript": "^5.3.3"
  }
}
